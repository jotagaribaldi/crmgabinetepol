// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ROOT
  POLITICO
  CHEFEGAB
  COORDENADOR
  LIDERREG
  LIDERLOCAL
}

enum Sex {
  MASCULINO
  FEMININO
  OUTRO
}

enum SupportStatus {
  CONFIRMADO
  PROVAVEL
  INDEFINIDO
  CONTRARIO
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  EXPORT
  IMPORT
}

// ─────────────────────────────────────────────
// TENANTS (Candidatos)
// ─────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  document  String?  @unique
  email     String?
  phone     String?
  party     String?
  position  String?
  state     String?
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  regions       Region[]
  segments      Segment[]
  voters        Voter[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]

  @@map("tenants")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  tenantId     String?
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(LIDERLOCAL)
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  coordinatedRegions     Region[] @relation("RegionCoordinator")
  votersAsCoordinator    Voter[]  @relation("VoterCoordinator")
  votersAsRegionalLeader Voter[]  @relation("VoterRegionalLeader")
  votersAsLocalLeader    Voter[]  @relation("VoterLocalLeader")
  createdVoters          Voter[]  @relation("VoterCreatedBy")

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────
// REFRESH TOKENS
// ─────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  tenantId  String?
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// TERRITORIAL STRUCTURE
// ─────────────────────────────────────────────

model State {
  id           String   @id @default(uuid())
  name         String
  abbreviation String   @unique
  ibgeCode     String   @unique
  createdAt    DateTime @default(now())

  municipalities Municipality[]
  regions        Region[]

  @@map("states")
}

model Municipality {
  id        String   @id @default(uuid())
  stateId   String
  name      String
  ibgeCode  String   @unique
  createdAt DateTime @default(now())

  state       State                @relation(fields: [stateId], references: [id])
  regionLinks RegionMunicipality[]
  voters      Voter[]

  @@index([stateId])
  @@index([name])
  @@map("municipalities")
}

model Region {
  id            String   @id @default(uuid())
  tenantId      String
  stateId       String
  coordinatorId String?
  name          String
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  state          State                @relation(fields: [stateId], references: [id])
  coordinator    User?                @relation("RegionCoordinator", fields: [coordinatorId], references: [id])
  municipalities RegionMunicipality[]
  voters         Voter[]

  @@index([tenantId])
  @@index([coordinatorId])
  @@map("regions")
}

model RegionMunicipality {
  id             String @id @default(uuid())
  regionId       String
  municipalityId String

  region       Region       @relation(fields: [regionId], references: [id], onDelete: Cascade)
  municipality Municipality @relation(fields: [municipalityId], references: [id])

  @@unique([regionId, municipalityId])
  @@map("region_municipalities")
}

// ─────────────────────────────────────────────
// SEGMENTS
// ─────────────────────────────────────────────

model Segment {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  voters Voter[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("segments")
}

// ─────────────────────────────────────────────
// VOTERS (Eleitores) - Entidade principal
// ─────────────────────────────────────────────

model Voter {
  id               String  @id @default(uuid())
  tenantId         String
  municipalityId   String?
  regionId         String?
  segmentId        String?
  coordinatorId    String?
  regionalLeaderId String?
  localLeaderId    String?
  createdById      String?

  name      String
  phone     String?
  whatsapp  String?
  email     String?
  cpf       String?
  birthDate DateTime?
  sex       Sex?

  address      String?
  number       String?
  complement   String?
  neighborhood String?
  zipCode      String?

  supportStatus SupportStatus @default(INDEFINIDO)
  observations  String?
  isActive      Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  municipality   Municipality? @relation(fields: [municipalityId], references: [id])
  region         Region?       @relation(fields: [regionId], references: [id])
  segment        Segment?      @relation(fields: [segmentId], references: [id])
  coordinator    User?         @relation("VoterCoordinator", fields: [coordinatorId], references: [id])
  regionalLeader User?         @relation("VoterRegionalLeader", fields: [regionalLeaderId], references: [id])
  localLeader    User?         @relation("VoterLocalLeader", fields: [localLeaderId], references: [id])
  createdBy      User?         @relation("VoterCreatedBy", fields: [createdById], references: [id])

  @@unique([tenantId, cpf], name: "unique_cpf_per_tenant")
  @@unique([tenantId, phone], name: "unique_phone_per_tenant")
  @@unique([tenantId, whatsapp], name: "unique_whatsapp_per_tenant")
  @@index([tenantId])
  @@index([municipalityId])
  @@index([regionId])
  @@index([segmentId])
  @@index([coordinatorId])
  @@index([regionalLeaderId])
  @@index([localLeaderId])
  @@index([name])
  @@index([cpf])
  @@map("voters")
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(uuid())
  tenantId  String?
  userId    String?
  action    AuditAction
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
